# Auto detect text files and normalize line endings to LF
* text=auto

# Source code languages
*.ts linguist-language=TypeScript
*.tsx linguist-language=TypeScript
*.js linguist-language=JavaScript
*.jsx linguist-language=JavaScript
*.rs linguist-language=Rust
*.toml linguist-language=TOML

# Ensure Rust files are counted
PrivatePokerContract.rs linguist-language=Rust -linguist-vendored
programs/privatepoker/src/** linguist-language=Rust -linguist-vendored

# Exclude test and build files
test_*.js linguist-vendored
test_*.mjs linguist-vendored
test_*.ts linguist-vendored
verify_deployment.js linguist-vendored
transfer_funds.js linguist-vendored
node_modules/ linguist-vendored
.next/ linguist-vendored
target/ linguist-vendored
dist/ linguist-vendored
build/ linguist-vendored
*.lock linguist-vendored
target/ linguist-vendored
*.lock linguist-vendored
*.md linguist-documentation
